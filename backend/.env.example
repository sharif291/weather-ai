# Server Port Configuration
PORT=3000

# PostgreSQL database connection URL (e.g., Neon, Supabase, or RDS)
# Example: postgresql://username:password@hostname:5432/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/terraclimate"

# WeatherAI API Configuration
WEATHER_AI_API_KEY="your_weather_ai_api_key_here"

# Caching Configuration (Requires Redis)
REDIS_URL="redis://localhost:6379"

# AWS Configuration (SQS notifications & S3 uploads)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="test"
AWS_SECRET_ACCESS_KEY="test"
AWS_S3_UPLOAD_BUCKET="terraclimate-uploads-bucket"

# AWS SQS Queue URLs (Use local ElasticMQ endpoints for local development)
# For local dev: http://localhost:9324/queue/terraclimate-notification-queue
AWS_SQS_QUEUE_URL="http://localhost:9324/queue/terraclimate-notification-queue"
# Set AWS_ENDPOINT_URL_SQS to connect standard SDK commands to local SQS emulator (ElasticMQ)
AWS_ENDPOINT_URL_SQS="http://localhost:9324"

# Firebase Admin Configuration (Required for Auth token validation & Realtime alerts)
# Values can be obtained from the Firebase Console (Service Accounts)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-firebase-project-id.iam.gserviceaccount.com"
# Note: Private key must preserve newline characters
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
