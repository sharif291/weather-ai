datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id // Matches Firebase Auth UID
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  farms     Farm[]
}

model Farm {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  latitude      Float
  longitude     Float
  cropType      String       // e.g. "Tea", "Maize", "Wheat"
  imageUrl      String?      // S3 uploaded drone map / satellite photo link
  region        String?
  country       String?
  timezone      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  alertConfig   AlertConfig?
  alertLogs     AlertLog[]

  @@index([userId])
}

model AlertConfig {
  id             String   @id @default(uuid())
  farmId         String   @unique
  farm           Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  windThreshold  Float    @default(20.0)
  rainThreshold  Float    @default(10.0)
  enabled        Boolean  @default(true)
  notifyEmail    Boolean  @default(false)
  emailAddress   String?
  notifySms      Boolean  @default(false)
  phoneNumber    String?
  notifyDiscord  Boolean  @default(false)
  discordWebhook String?
  notifyInApp    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AlertLog {
  id        String   @id @default(uuid())
  farmId    String
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  type      String   // e.g., "WIND_ALERT", "UV_ALERT", "STORM_ALERT"
  message   String
  status    String   // e.g., "DISPATCHED", "FAILED"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([farmId])
}
