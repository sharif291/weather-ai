# Base URL of the backend API
# During local development, Vite proxies this port to http://localhost:3000
VITE_API_URL="http://localhost:3000"

# Firebase Client SDK Credentials (Required for authentication and realtime notifications)
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-firebase-auth-domain"
VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-firebase-storage-bucket"
VITE_FIREBASE_SENDER_ID="your-firebase-sender-id"
VITE_FIREBASE_APP_ID="your-firebase-app-id"
